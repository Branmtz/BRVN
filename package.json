{
  "name": "paps-store",
  "version": "1.0.0",
  "description": "PAPS minimalist online store and Price Shoes scraper",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "dev:local": "node --watch-path=server.js --watch-path=scraper.js --watch-path=database.js --watch-path=public run-local.js",
    "postinstall": "npx playwright install --with-deps chromium"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^3.1.0",
    "nodemailer": "^8.0.11",
    "playwright": "^1.44.1",
    "sqlite3": "^5.1.7"
  }
}
